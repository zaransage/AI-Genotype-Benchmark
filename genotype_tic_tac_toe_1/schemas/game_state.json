{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "GameState",
    "description": "Canonical wire format for a tic-tac-toe game state",
    "type": "object",
    "required": ["game_id", "board", "current_player", "status", "winner"],
    "additionalProperties": false,
    "properties": {
        "game_id": {
            "type": "string",
            "description": "UUID of the game"
        },
        "board": {
            "type": "array",
            "description": "3x3 grid; empty string = unoccupied",
            "minItems": 3,
            "maxItems": 3,
            "items": {
                "type": "array",
                "minItems": 3,
                "maxItems": 3,
                "items": {
                    "type": "string",
                    "enum": ["", "X", "O"]
                }
            }
        },
        "current_player": {
            "type": "string",
            "enum": ["X", "O"],
            "description": "Whose turn it is"
        },
        "status": {
            "type": "string",
            "enum": ["active", "x_wins", "o_wins", "draw"],
            "description": "Game outcome or active state"
        },
        "winner": {
            "type": ["string", "null"],
            "enum": ["X", "O", null],
            "description": "Winning player symbol, or null if no winner yet"
        }
    }
}
