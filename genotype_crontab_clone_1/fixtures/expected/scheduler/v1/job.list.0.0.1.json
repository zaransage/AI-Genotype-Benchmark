[
  {
    "name": "cleanup-logs",
    "command": "find /var/log -name '*.log' -mtime +7 -delete",
    "cron_expression": "0 2 * * *",
    "enabled": true
  },
  {
    "name": "backup-db",
    "command": "pg_dump mydb > /backups/mydb.sql",
    "cron_expression": "30 3 * * 0",
    "enabled": true
  }
]
